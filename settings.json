{
  "env": {
    "EDITOR": "vim"
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(cd:*)",
      "Bash(echo:*)",
      "Bash(fd:*)",
      "Bash(file:*)",
      "Bash(find . -name:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(git blame:*)",
      "Bash(git branch:*)",
      "Bash(git check-ignore:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git config --get:*)",
      "Bash(git config --list)",
      "Bash(git describe:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git ls-files:*)",
      "Bash(git merge-base:*)",
      "Bash(git pull --ff-only:*)",
      "Bash(git push:*)",
      "Bash(git reflog:*)",
      "Bash(git remote -v)",
      "Bash(git remote show:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show:*)",
      "Bash(git stash list)",
      "Bash(git stash show:*)",
      "Bash(git status:*)",
      "Bash(git tag:*)",
      "Bash(git worktree list)",
      "Bash(go build:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(jq:*)",
      "Bash(ls:*)",
      "Bash(make:*)",
      "Bash(node --test:*)",
      "Bash(npm ls:*)",
      "Bash(npm outdated:*)",
      "Bash(npm view:*)",
      "Bash(pip list:*)",
      "Bash(pip show:*)",
      "Bash(pwd)",
      "Bash(rg:*)",
      "Bash(tail:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(yq:*)"
    ],
    "deny": [
      "Bash(aws configure:*)",
      "Bash(chmod -R:*)",
      "Bash(chmod 777:*)",
      "Bash(eval:*)",
      "Bash(gcloud auth application-default print-access-token:*)",
      "Bash(gcloud auth print-access-token:*)",
      "Bash(gcloud auth print-identity-token:*)",
      "Bash(gh auth token)",
      "Bash(git push --force origin main:*)",
      "Bash(git push --force origin master:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf:*)",
      "Bash(security find-generic-password:*)",
      "Bash(security find-internet-password:*)",
      "Bash(source:*)",
      "Bash(su:*)",
      "Bash(sudo:*)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/*service-account*.json)",
      "Read(**/id_rsa*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.netrc)",
      "Read(~/.ssh/**)"
    ],
    "ask": [
      "Bash(curl:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(wget:*)",
      "Edit(~/.claude/hooks/**)",
      "Edit(~/.claude/settings.json)",
      "Write(~/.claude/settings.json)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify-slack.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@2.2.12",
    "padding": 0
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "session-report@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "impeccable": {
      "source": {
        "source": "github",
        "repo": "pbakaus/impeccable"
      }
    },
    "harness-marketplace": {
      "source": {
        "source": "github",
        "repo": "revfactory/harness"
      }
    },
    "harness-flow": {
      "source": {
        "source": "github",
        "repo": "wonjinsin/harness-flow"
      }
    },
    "everything-claude-code": {
      "source": {
        "source": "git",
        "url": "https://github.com/affaan-m/everything-claude-code.git"
      }
    }
  },
  "advisorModel": "opus",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true
}
